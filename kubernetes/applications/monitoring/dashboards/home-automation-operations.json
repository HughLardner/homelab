      "targets": [
        {
          "expr": "{namespace=\"$namespace\", pod=~\"$pod\"} |~ \"(?i)error|exception|fail|timeout\"",
          "refId": "A"
        }
      ],
      "title": "Recent Error Logs",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${logsDatasource}"
      },
      "gridPos": {
        "h": 12,
