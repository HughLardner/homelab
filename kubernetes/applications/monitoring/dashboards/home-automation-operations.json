        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[24h])))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Restarts by Pod (24h)",
      "type": "timeseries"
    },
    {
      "datasource": {
